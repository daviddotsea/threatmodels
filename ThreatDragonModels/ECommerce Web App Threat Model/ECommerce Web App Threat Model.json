            "data": {
              "type": "tm.Process",
              "name": "Web Server / Web App",
              "description": "",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": false,
              "privilegeLevel": "",
              "threats": [
                {
                  "id": "c8529113-64fa-4fe2-b138-d14ec396d27c",
                  "title": "Weak authentication allows impersonation",
                  "status": "Open",
                  "severity": "High",
                  "type": "Spoofing",
                  "description": "An attacker may impersonate a legitimate customer due to weak or missing authentication controls.\n",
                  "mitigation": "Implement multi‑factor authentication (MFA) and enforce strong password controls.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 1,
                  "score": "8"
                },
                {
                  "id": "891102fb-32c7-4254-bc3e-5042d049e149",
                  "title": "Input not validated allows data manipulation",
                  "status": "Open",
                  "severity": "High",
                  "type": "Tampering",
                  "description": "An attacker may modify price or inventory values by submitting malicious or altered input due to insufficient server‑side validation.\n",
                  "mitigation": "Implement strict server‑side input validation and sanitize all form inputs.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 2,
                  "score": "7.5"
                },
                {
                  "id": "82aefc21-a45f-4e3f-ab9b-51096751413b",
                  "title": "Lack of logging allows denial of actions",
                  "status": "Open",
                  "severity": "Medium",
                  "type": "Repudiation",
                  "description": "Because the system does not maintain sufficient logs, a user or attacker may deny performing transactions or actions, and there would be no reliable audit trail to prove otherwise.\n",
                  "mitigation": "Implement detailed server‑side logging and audit trails for all critical actions, including authentication and transaction events.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 3,
                  "score": "5"
                },
                {
                  "id": "b43bd5ff-d42c-470e-a60b-2ed8e86d7213",
                  "title": "Plaintext credentials may be exposed",
                  "status": "Open",
                  "severity": "High",
                  "type": "Information disclosure",
                  "description": "Sensitive information such as customer passwords may be stored or transmitted in plaintext, allowing attackers to read or intercept confidential data.\n",
                  "mitigation": "Use strong hashing (bcrypt) for passwords and encrypt sensitive data in transit and at rest.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 4,
                  "score": "8.0"
                },
                {
                  "id": "7f87a623-b2ef-467d-a89b-2527b0c5cf06",
                  "title": "Unrestricted requests or uploads can exhaust server resources",
                  "status": "Open",
                  "severity": "High",
                  "type": "Denial of service",
                  "description": "The application does not limit request rates or file upload size, allowing an attacker to overwhelm the server or fill available storage, making the service unavailable.\n",
                  "mitigation": "Implement rate limiting and restrict upload size, type, and frequency. Monitor resource usage and enforce quotas.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 5,
                  "score": "7.5"
                },
                {
                  "id": "0b21f2a9-eaa6-46f5-8ac2-db8ce86061cb",
                  "title": "SQL injection may allow unauthorized privilege escalation",
                  "status": "Open",
                  "severity": "High",
                  "type": "Elevation of privilege",
                  "description": "Improperly sanitized user input may allow an attacker to inject SQL commands, gaining elevated permissions or full database access.\n",
                  "mitigation": "Use prepared SQL statements, parameterized queries, and enforce strict input validation.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 6,
                  "score": "9.0"
                },
                {
                  "id": "e0e74bc3-6c66-408a-bce7-fca8c249c585",
                  "title": "Data intercepted in transit",
                  "status": "Open",
                  "severity": "High",
                  "type": "Information disclosure",
                  "description": "If data traveling between the customer and the web server is not properly encrypted, an attacker may intercept or read sensitive information such as login credentials or session identifiers during transmission.\n",
                  "mitigation": "Enforce HTTPS/TLS 1.2 or higher, enable HSTS, and ensure strong certificate configurations.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 13,
                  "score": "7.5"
                },
                {
                  "id": "0bba0bed-ccbd-4189-81c9-f10318402c17",
                  "title": "Man‑in‑the‑middle modification of data",
                  "status": "Open",
                  "severity": "Medium",
                  "type": "Tampering",
                  "description": "An attacker positioned between the customer and the web server could alter data in transit if communication is not properly protected. This could include modifying form submissions, injecting malicious input, or altering responses.\n",
                  "mitigation": "Use HTTPS/TLS with strong ciphers, enable HSTS, validate all inputs server‑side, and verify integrity of critical data fields.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 14,
                  "score": "6.5"
                },
                {
                  "id": "1eb2341e-6750-43bb-9924-a99961c91482",
                  "title": "Excessive or malicious traffic exhausts server resources",
                  "status": "Open",
                  "severity": "Medium",
                  "type": "Denial of service",
                  "description": "An attacker may send a high volume of requests or large payloads through normal application data flows, overwhelming the web server. This may include repeated POST requests, oversized uploads, or resource‑intensive queries, causing service degradation or downtime.\n",
                  "mitigation": "Implement rate limiting, throttle incoming requests, restrict maximum request size, enforce upload limits, and monitor server resource usage.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 15,
                  "score": "6.0"
                }
              ]
            },
            "children": [
              "a89c4e9c-cee1-4ed3-a295-f981731e710b"
            ]
