              "threats": [
                {
                  "id": "22591459-41c5-4e82-bea3-4ffab922d02c",
                  "title": "Stolen or forged customer credentials",
                  "status": "Open",
                  "severity": "Medium",
                  "type": "Spoofing",
                  "description": "An attacker may impersonate a legitimate customer by using stolen, reused, or brute‑forced credentials obtained through phishing or other attacks.",
                  "mitigation": "Implement MFA, enforce strong passwords, add rate limiting, and monitor for credential stuffing attacks.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 8,
                  "score": "6"
                },
                {
                  "id": "be059789-8132-45f1-bf6a-39475a0f83ea",
                  "title": "Customer denies actions without proper audit trails",
                  "status": "Open",
                  "severity": "Low",
                  "type": "Repudiation",
                  "description": "A customer could deny making purchases or account changes if the system lacks sufficient logging and traceability of user actions.\n",
                  "mitigation": "Enable detailed logging with timestamps, IP addresses, user IDs, and unique transaction identifiers to support non‑repudiation.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 9,
                  "score": "4"
                }
              ]
            }
