            "data": {
              "type": "tm.Store",
              "name": "MySQL Database",
              "description": "",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "isALog": false,
              "isEncrypted": false,
              "isSigned": false,
              "storesCredentials": false,
              "storesInventory": false,
              "threats": [
                {
                  "id": "36134509-f7ac-45ec-9208-c2e7abc9a886",
                  "title": "Sensitive data stored without proper encryption",
                  "status": "Open",
                  "severity": "High",
                  "type": "Information disclosure",
                  "description": "Sensitive customer information such as passwords or personally identifiable data may be stored in plaintext or protected with weak cryptographic methods. If an attacker gains access to the database, this data could be directly exposed.\n",
                  "mitigation": "Use bcrypt for password hashing, encrypt sensitive data at rest, and secure database backups to prevent unauthorized data exposure.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 10,
                  "score": "8"
                },
                {
                  "id": "d78a73db-635f-4105-9d3f-af1cb893b49f",
                  "title": "Unauthorized modification of database records",
                  "status": "Open",
                  "severity": "High",
                  "type": "Tampering",
                  "description": "If the database is accessed due to SQL injection or misconfigured permissions, an attacker may modify customer records, inventory data, or order information, impacting data integrity and system reliability.\n",
                  "mitigation": "Enforce strict least‑privilege roles for database users, require prepared SQL statements, validate all input at the application layer, and enable database integrity controls.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 11,
                  "score": "7.5"
                },
                {
                  "id": "c1c5202a-066a-441c-ba14-de64f179683c",
                  "title": "Excessive database privileges enabling privilege escalation",
                  "status": "Open",
                  "severity": "Medium",
                  "type": "Elevation of privilege",
                  "description": "If the application connects to the database using an account with overly broad privileges, an attacker who compromises the web application may escalate privileges in the database, gaining additional access beyond what is intended.\n",
                  "mitigation": "Use separate read-only and read-write database accounts, apply strict least‑privilege permissions, and audit database role assignments regularly.\n",
                  "modelType": "default",
                  "new": false,
                  "number": 12,
                  "score": "6.5"
                }
              ]
            }
          },
